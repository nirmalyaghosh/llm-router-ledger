# llm-router-ledger environment variables
# Copy to .env and fill in real values. Never commit .env.

# Run identification (optional). Stamped on every JSONL event
# so you can group events by experimental condition.
LRL_RUN_TAG=
LRL_RUN_LABEL=

# Default YAML config path used when load_config() is called
# with no argument (optional).
LRL_CONFIG_PATH=

# Provider API keys for verified providers.
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
QWEN_API_KEY=
ZHIPU_API_KEY=

# Local Ollama. Any non-empty string works; "ollama" is the convention.
OLLAMA_API_KEY=ollama
